// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  phone     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model News {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  imagePath String?

  @@map("news")
}

model Products {
  id                   Int                          @id @default(autoincrement())
  name                 String
  short                String                       @unique
  eng                  String                       @unique
  description          String
  characteristics      String?
  features             String?
  imagePaths           String[]
  documents            ProductDocuments[]
  softwares            ProductSoftwares[]
  extraCharacteristics ProductExtraCharacteristic[]

  category   Categories? @relation(fields: [categoryId], references: [id])
  categoryId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model ProductDocuments {
  id   Int    @id @default(autoincrement())
  name String
  path String

  product   Products @relation(fields: [productId], references: [id])
  productId Int

  @@map("product_documents")
}

model ProductSoftwares {
  id   Int    @id @default(autoincrement())
  name String
  path String

  product   Products @relation(fields: [productId], references: [id])
  productId Int

  @@map("product_softwares")
}

model ProductExtraCharacteristic {
  id    Int    @id @default(autoincrement())
  key   String
  value String

  product   Products @relation(fields: [productId], references: [id])
  productId Int

  @@map("product_extra_characteristics")
}

model Categories {
  id   Int    @id @default(autoincrement())
  name String
  url  String

  imagePath String?

  section   Sections @relation(fields: [sectionId], references: [id])
  sectionId Int

  products Products[]

  @@map("categories")
}

model Sections {
  id   Int    @id @default(autoincrement())
  name String
  url  String

  imagePath String?

  categories Categories[]

  @@map("sections")
}
